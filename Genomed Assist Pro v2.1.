@app.post("/doctor/register", tags=["Doctors"], status_code=201)
def register_doctor(doctor: DoctorRegister):
    conn = get_db()
    c = conn.cursor()
    existing = c.execute(
        "SELECT username FROM doctors WHERE username=?",
        (doctor.username,)
    ).fetchone()
    if existing:
        conn.close()
        raise HTTPException(status_code=409, detail="Username already exists")
    c.execute(
        "INSERT INTO doctors (username, password, name, specialization)"
        " VALUES (?,?,?,?)",
        (doctor.username, hash_password(doctor.password),
         doctor.name, doctor.specialization)
    )
    conn.commit()
    conn.close()
    return {"message": "Doctor registered", "doctor": doctor.name}


@app.post("/doctor/login", tags=["Doctors"])
def login_doctor(data: LoginRequest):
    conn = get_db()
    doctor = conn.execute(
        "SELECT * FROM doctors WHERE username=?",
        (data.username,)
    ).fetchone()
    conn.close()
    if not doctor:
        raise HTTPException(status_code=404, detail="Doctor not found")
    if not verify_password(data.password, doctor["password"]):
        raise HTTPException(status_code=401, detail="Incorrect password")
    token = create_token(data.username)
    return {
        "message": "Welcome " + doctor["name"],
        "access_token": token,
        "token_type": "bearer"
    }


