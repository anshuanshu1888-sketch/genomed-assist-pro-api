        "SELECT * FROM patients WHERE doctor_id=?",
        (username,)
    ).fetchall()
    conn.close()
    return {
        "total": len(patients),
        "patients": [decrypt_patient(p) for p in patients]
    }


@app.post("/patient/add", tags=["Patients"], status_code=201)
def add_patient(
    patient: PatientCreate,
    username: str = Depends(get_current_user)
):
    conn = get_db()
    c = conn.cursor()
    existing = c.execute(
        "SELECT id FROM patients WHERE id=?",
        (patient.id,)
    ).fetchone()
    if existing:
        conn.close()
        raise HTTPException(status_code=409, detail="Patient ID exists")
    enc_diag = encrypt_data(patient.diagnosis)
    c.execute(
        "INSERT INTO patients"
        " (id, name, age, gender, phone, medical_data_encrypted, doctor_id)"
        " VALUES (?,?,?,?,?,?,?)",
        (patient.id, patient.name, patient.age,
         patient.gender, patient.phone, enc_diag, username)
    )
    conn.commit()
    conn.close()
    return {"message": "Patient added", "patient_id": patient.id}


