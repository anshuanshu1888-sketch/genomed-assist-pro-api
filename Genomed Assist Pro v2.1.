@app.get("/patient/{patient_id}", tags=["Patients"])
def get_patient(
    patient_id: str,
    username: str = Depends(get_current_user)
):
    conn = get_db()
    patient = conn.execute(
        "SELECT * FROM patients WHERE id=? AND doctor_id=?",
        (patient_id, username)
    ).fetchone()
    conn.close()
    if not patient:
        raise HTTPException(status_code=404, detail="Patient not found")
    return decrypt_patient(patient)


@app.delete("/patient/{patient_id}", tags=["Patients"])
def delete_patient(
    patient_id: str,
    username: str = Depends(get_current_user)
):
    conn = get_db()
    result = conn.execute(
        "DELETE FROM patients WHERE id=? AND doctor_id=?",
        (patient_id, username)
    )
    conn.commit()
    conn.close()
    if result.rowcount == 0:
        raise HTTPException(status_code=404, detail="Patient not found")
    return {"message": "Patient deleted"}


@app.post("/appointment/book", tags=["Appointments"], status_code=201)
def book_appointment(
    appointment: AppointmentCreate,
    username: str = Depends(get_current_user)
):
    conn = get_db()
    patient = conn.execute(
        "SELECT id FROM patients WHERE id=? AND doctor_id=?",
        (appointment.patient_id, username)
    ).fetchone()
    if not patient:
        conn.close()
        raise HTTPException(status_code=404, detail="Patient not found")
    conn.execute(
        "INSERT INTO appointments"
        " (patient_id, doctor_id, date, time, notes)"
        " VALUES (?,?,?,?,?)",
        (appointment.patient_id, username,
         appointment.date, appointment.time, appointment.notes)
    )
    conn.commit()
    conn.close()
    return {"message": "Appointment booked"}


@app.get("/appointments", tags=["Appointments"])
def list_appointments(username: str = Depends(get_current_user)):
    conn = get_db()
    items = conn.execute(
        "SELECT * FROM appointments WHERE doctor_id=? ORDER BY date, time",
        (username,)
    ).fetchall()
    conn.close()
    return {"total": len(items), "appointments": [dict(i) for i in items]}


@app.put("/appointment/{appointment_id}", tags=["Appointments"])
def update_appointment(
    appointment_id: int,
    update: AppointmentUpdate,
    username: str = Depends(get_current_user)
):
    allowed = {"scheduled", "completed", "cancelled"}
    if update.status not in allowed:
        raise HTTPException(status_code=400, detail="Invalid status")
    conn = get_db()
    result = conn.execute(
        "UPDATE appointments SET status=? WHERE id=? AND doctor_id=?",
        (update.status, appointment_id, username)
    )
    conn.commit()
    conn.close()
    if result.rowcount == 0:
        raise HTTPException(status_code=404, detail="Appointment not found")
    return {"message": "Appointment updated", "status": update.status}


